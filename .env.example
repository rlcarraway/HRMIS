# =============================================================================
# HRMIS Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to git - it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Used for session management and authentication

# Your application URL (use your actual deployment URL in production)
NEXTAUTH_URL=http://localhost:3000

# Secret key for NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# -----------------------------------------------------------------------------
# Okta OAuth Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# Only required if you want to enable Okta SSO
# If not set, users can still sign in with local accounts (admin@example.com)

# Okta application client ID
# OKTA_CLIENT_ID=your-okta-client-id

# Okta application client secret
# OKTA_CLIENT_SECRET=your-okta-client-secret

# Okta issuer URL (e.g., https://your-domain.okta.com/oauth2/default)
# OKTA_ISSUER=https://your-domain.okta.com/oauth2/default

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED for persistent storage)
# -----------------------------------------------------------------------------
# Required to migrate from ephemeral file-based storage to persistent database
# Get these from your Supabase project settings

# Supabase project URL (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (from Project Settings → API)
# Used for client-side operations with RLS policies
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (from Project Settings → API)
# Used for server-side operations, bypasses RLS - keep this secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Vercel Environment (AUTO-SET by Vercel)
# -----------------------------------------------------------------------------
# This is automatically set to "1" when running on Vercel
# Used to determine storage location (/tmp vs ./data)
# VERCEL=1

# =============================================================================
# Quick Setup Guide
# =============================================================================
#
# 1. NextAuth Setup:
#    - Generate secret: openssl rand -base64 32
#    - Set NEXTAUTH_URL to your deployment URL
#    - Set NEXTAUTH_SECRET to generated value
#
# 2. Okta Setup (Optional):
#    - Create Okta application (Web Application)
#    - Set redirect URI: https://your-app/api/auth/callback/okta
#    - Copy Client ID, Client Secret, and Issuer
#
# 3. Supabase Setup (Recommended for production):
#    - Create Supabase project at https://supabase.com
#    - Go to Project Settings → API
#    - Copy URL, anon key, and service_role key
#    - Run SQL schema from docs/SUPABASE_MIGRATION.md
#    - Update lib/serverStorage.ts to use Supabase
#
# 4. Local Development:
#    - Copy this file to .env.local
#    - Fill in actual values
#    - Run: npm run dev
#
# 5. Vercel Deployment:
#    - Add all variables in Vercel project settings
#    - Select environments (Production, Preview, Development)
#    - Redeploy after adding variables
#
# =============================================================================
#
# Default Local Users (available without Okta):
# Admin: admin@example.com / password
# Viewer: viewer@example.com / password
#
# =============================================================================
